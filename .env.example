# Patreon OAuth2 Credentials
# Get these from https://www.patreon.com/portal/registration/register-clients
PATREON_CLIENT_ID=your_patreon_client_id

PATREON_CLIENT_SECRET=your_patreon_client_secret

PATREON_REDIRECT_URI=http://localhost:3847/callback

# Your Patreon campaign ID (find it in your campaign dashboard URL)
PATREON_CAMPAIGN_ID=your_campaign_id

# Minimum pledge amount in cents to qualify (0 = any active patron)
MIN_TIER_CENTS=300

# JWT signing secret — use a long random string
JWT_SECRET=replace_with_a_long_random_secret

# Auth server port
AUTH_PORT=3847
